# Ejemplo vLLM/nube:     CUSTOM_LLM_URL=https://tu-servidor.com/v1
CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=qwen3.6:35b

# Admin - URL y contraseña del panel de moderación
ADMIN_PASSWORD=intercoop2025

# URL pública de la app (para el QR)
NEXT_PUBLIC_APP_URL=https://rn-intercoop.vercel.app
